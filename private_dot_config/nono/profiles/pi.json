{
  "extends": "default",
  "meta": {
    "name": "pi",
    "description": "Profile for Pi coding harness"
  },
  "groups": {
    "include": []
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": ["~/.config/pi/agent", "/tmp", "~/.config/rpiv-web-tools"],
    "read": [
      "~/.bun/bin",
      "~/.bun/install/global",
      "~/.local/share/fnm",
      "/run/user/1000/fnm_multishells"
    ],
    "allow_file": ["/usr/bin/env"]
  }
}
