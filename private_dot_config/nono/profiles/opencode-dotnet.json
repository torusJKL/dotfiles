{
  "meta": {
    "name": "opencode-dotnet",
    "description": "opencode + /proc for .NET"
  },
  "extends": "opencode",
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read": [
      "/proc",
      "$HOME/.nuget",
      "$HOME/.local/share/NuGet",
      "$XDG_CONFIG_HOME/opencode",
      "$XDG_CACHE_HOME/opencode",
      "$XDG_DATA_HOME/opencode",
      "$XDG_DATA_HOME/opentui"
    ],
    "write": ["$HOME/.nuget", "$HOME/.local/share/NuGet"],
    "execute": ["$HOME/.opencode/bin"]
  },
  "network": {
    "block": false
  }
}
